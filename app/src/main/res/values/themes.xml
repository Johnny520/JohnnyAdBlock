<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.JohnnyAdBlock" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimary</item>
    </style>

    <!-- 液态玻璃 UI（默认主题 · 日间 · MaterialComponents） -->
    <style name="Theme.LiquidGlass" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/glass_window_bg</item>
        <item name="colorPrimary">@color/glass_primary</item>
        <item name="colorOnPrimary">@color/glass_on_primary</item>
        <item name="colorPrimaryContainer">@color/glass_primary_container</item>
        <item name="colorSecondary">@color/glass_secondary</item>
        <item name="colorSurface">@color/glass_surface</item>
        <item name="colorOnSurface">@color/glass_on_surface</item>
        <item name="colorOutline">@color/glass_outline</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/glass_nav</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>