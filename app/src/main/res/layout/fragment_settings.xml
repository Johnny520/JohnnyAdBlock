<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="高级功能" android:textSize="18sp" android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- 禁用FLAG_SECURE -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="禁用 FLAG_SECURE（防截图/录屏）"/>
            <SwitchCompat android:id="@+id/switch_flag_secure" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- 过VPN检测 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="过 VPN 检测"/>
            <SwitchCompat android:id="@+id/switch_vpn_detect" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- 过实名认证 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="过实名认证（王者/CF）"/>
            <SwitchCompat android:id="@+id/switch_real_name" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- 去除弹窗 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="去除常见弹窗（云注入/清羽）"/>
            <SwitchCompat android:id="@+id/switch_popup" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- 去除广告 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="去除常见广告"/>
            <SwitchCompat android:id="@+id/switch_ad" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- 破解VIP -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="破解VIP/会员"/>
            <SwitchCompat android:id="@+id/switch_vip" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- 网易游戏 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="网易游戏 iOS强制登录"/>
            <SwitchCompat android:id="@+id/switch_netease" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- replaceSu+ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="replaceSu+（自定义su路径）"/>
            <SwitchCompat android:id="@+id/switch_replace_su" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- JustTrustMe -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="JustTrustMe（绕过SSL证书检查）"/>
            <SwitchCompat android:id="@+id/switch_just_trust_me" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- 抖音抓包防断网 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="抖音抓包防断网（强制HTTP）"/>
            <SwitchCompat android:id="@+id/switch_douyin_http" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE"/>

        <!-- 加速器代理白名单 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="加速器代理白名单"/>
            <SwitchCompat android:id="@+id/switch_proxy_whitelist" android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>